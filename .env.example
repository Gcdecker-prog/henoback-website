# ─── Production (Vercel: henoback-website) ───────────────────────────────────

# Canonical marketing site URL (no trailing slash)
# Production: https://henobackoffice.com
# Preview:    https://henoback-website.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GTM Sales Engine origin (no trailing slash)
# Production: your gtm-sales-engine.vercel.app or custom domain
NEXT_PUBLIC_GTM_APP_URL=http://localhost:3001

# Intake form path on GTM app (default /intake)
NEXT_PUBLIC_GTM_INTAKE_PATH=/intake
