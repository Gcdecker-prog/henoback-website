# Copy to .env.local — never commit .env.local
# https://github.com/.../henoback-website

# ─── Public (safe in browser — no secrets) ───────────────────────────────────

# Canonical marketing URL (no trailing slash)
# Local:      http://localhost:3000
# Preview:    https://henoback-website.vercel.app
# Production: https://henobackoffice.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GTM Sales Engine origin (no trailing slash)
NEXT_PUBLIC_GTM_APP_URL=http://localhost:3001

# Intake path on GTM app
NEXT_PUBLIC_GTM_INTAKE_PATH=/intake

# ─── Server only (never NEXT_PUBLIC_ — not exposed to visitors) ───────────────

# Internal /campaigns UTM playbook — local dev only. Do NOT set on Vercel Production.
# CAMPAIGN_PLAYBOOK_ENABLED=true
